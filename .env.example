# Passphrases opcionales para llaves privadas SSH.
# Solo definir si la llave correspondiente está cifrada con passphrase.
# Formato: SSH_PASSPHRASE_<NOMBRE_PERFIL_UPPERCASE>=valor
# Ejemplo:
SSH_PASSPHRASE_PRODUCCION=tu_passphrase_si_aplica
SSH_PASSPHRASE_STAGING=tu_passphrase_si_aplica

# Opcional: ruta personalizada al archivo profiles.json
# SSH_PROFILES_PATH=/ruta/absoluta/a/profiles.json
